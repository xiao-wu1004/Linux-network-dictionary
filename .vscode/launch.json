{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug dict_client",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/dict_client",
      "args": ["127.0.0.1", "8888"],
      "stopAtEntry": false,
      "externalConsole": false,
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Debug dict_server",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/dict_server",
      "args": ["127.0.0.1", "8888"],
      "stopAtEntry": false,
      "externalConsole": false,
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
